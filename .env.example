COMPOSE_PROJECT_NAME=kizuna
GROQ_API_KEY=

# Brevo — alertas de saúde (notification-service)
# Painel: https://app.brevo.com → Configurações → SMTP e API → Chave SMTP (NÃO use a chave API v3 aqui)
# Chave fixa para sistemas externos lerem métricas (data-service /integration/v1)
KIZUNA_INTEGRATION_BOOTSTRAP_KEY=kz_live_troque_por_uma_chave_longa

KIZUNA_HEALTH_ALERT_ENABLED=true
KIZUNA_HEALTH_ALERT_RECIPIENTS=admin@seu-dominio.com
KIZUNA_HEALTH_ALERT_FROM=remetente-verificado@seu-dominio.com
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=remetente-verificado@seu-dominio.com
SMTP_PASSWORD=sua-chave-smtp-brevo-aqui
